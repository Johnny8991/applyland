{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "buildCommand": "npm run vercel-build",
  "outputDirectory": ".tmp/public",
  "functions": {
    "api/index.js": {
      "includeFiles": "{app/**,.tmp/**,server.js,package.json,node_modules/govuk-prototype-kit/**,node_modules/govuk-frontend/**,node_modules/browser-sync*/**}"
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api"
    }
  ]
}
